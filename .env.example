# =============================================================================
# onec-vecgraph — конфигурация (.env). Скопируйте в .env и отредактируйте.
# Все ключи читаются pydantic-settings (регистр не важен; .env в .gitignore).
# В Docker те же значения прокидываются через docker-compose.yml.
# Детальный разбор запуска: docs/DEPLOY_DETAILED.md
# =============================================================================

# ── Сборка Docker-образа (build-args; docker compose читает их из этого .env) ─
# Это переменные ЭТАПА СБОРКИ образа (не рантайма). На Windows задавайте их здесь и
# запускайте обычный `docker compose build` — форма «VAR=... docker compose build» это bash
# и в CMD/PowerShell не работает. Альтернатива на одну команду: docker compose build --build-arg VAR=...
# Состав образа: local-embeddings (torch + sentence-transformers) | cloud-embeddings (без torch).
# EXTRAS=local-embeddings
# Источник torch (только при EXTRAS=local-embeddings): .../whl/cpu (по умолч.) или .../whl/cu128 (GPU).
# TORCH_INDEX_URL=https://download.pytorch.org/whl/cu128

# ── Neo4j (единое хранилище: граф + векторы(HNSW) + полнотекст) ──────────────
# Адрес подключения. Локальный CLI → localhost. В docker-compose сервис app сам
# выставляет bolt://neo4j:7687 (имя сервиса). Менять при внешнем/удалённом Neo4j.
NEO4J_URI=bolt://localhost:7687
# Пользователь БД. По умолчанию neo4j.
NEO4J_USER=neo4j
# ПАРОЛЬ БД. Значение ниже — только для локальной разработки. В проде ОБЯЗАТЕЛЬНО
# сменить (compose прокидывает его и в контейнер neo4j, и в app).
NEO4J_PASSWORD=onec_vecgraph_dev
# Имя базы. На Neo4j Community доступна одна БД 'neo4j'. Меняют при переходе на
# схему «БД-на-арендатора» (Enterprise/Aura).
NEO4J_DATABASE=neo4j

# ── Эмбеддинги ──────────────────────────────────────────────────────────────
# ВАЖНО: provider+model должны СОВПАДАТЬ при индексации (vectorize/ingest) и при
# работе сервера. Размерность векторного индекса фиксируется при первой
# векторизации; смешение моделей/размерностей на одной БД ломает поиск.
#
# Провайдер: hashing | local | openai | voyage
#   hashing — без ML, детерминированный хеш. Только для dev/тестов (плохое качество).
#   local   — sentence-transformers (Qwen3-Embedding / BGE-m3). Нужен: uv sync --extra local-embeddings.
#   openai  — text-embedding-3-large / -small или OpenAI-совместимый шлюз. Нужен: --extra cloud-embeddings.
#   voyage  — voyage-3 / voyage-3-large / ...                          Нужен: --extra cloud-embeddings.
EMBEDDING_PROVIDER=hashing
# Модель эмбеддингов.
#   local : Qwen/Qwen3-Embedding-0.6B (1024-dim, дефолт), Qwen/Qwen3-Embedding-4B (2560, качество), BAAI/bge-m3.
#   openai: text-embedding-3-large (3072) / text-embedding-3-small (1536).
#   voyage: voyage-3 (1024) / voyage-3-large / voyage-3.5-lite.
EMBEDDING_MODEL=BAAI/bge-m3
# Устройство для local-провайдера: auto | cpu | cuda (auto = cuda, если доступна).
# Для GPU-профиля — cuda (нужен torch cu128 и --gpus).
EMBEDDING_DEVICE=cpu
# Размер батча при эмбеддинге. На больших конфигурациях (ERP) поднимать до 32–64
# (быстрее, но больше VRAM/RAM).
EMBEDDING_BATCH_SIZE=16
# Максимум токенов на чанк. Ограничивает VRAM (внимание ~O(n^2)) и ускоряет.
# Увеличивать только если чанки реально длиннее и хватает памяти.
EMBEDDING_MAX_SEQ_LENGTH=256
# Имя промпта запроса для sentence-transformers (query-сторона, напр. у Qwen3).
# Обычно менять не нужно.
EMBEDDING_QUERY_PROMPT=query
# Размерность ТОЛЬКО для провайдера hashing. Для local/cloud игнорируется (берётся из модели).
EMBEDDING_DIM=256
# Cloud-only: усечь выходную размерность (OpenAI text-embedding-3-*, Voyage 3-large/3.5); ≤ 4096.
# Пусто = размерность по умолчанию у модели.
# EMBEDDING_DIMENSIONS=1024
# Во сколько раз увеличить выборку кандидатов до фильтрации по арендатору (over-fetch).
# Обычно менять не нужно.
# VECTOR_OVERFETCH=5
# Ключ OpenAI (при EMBEDDING_PROVIDER=openai).
# OPENAI_API_KEY=
# OpenAI-совместимый шлюз (Azure / прокси / self-hosted), напр. https://gateway/v1.
# OPENAI_BASE_URL=
# Ключ Voyage (при EMBEDDING_PROVIDER=voyage).
# VOYAGE_API_KEY=
# Токен HuggingFace — снимает rate-limit при скачивании local-модели (опц.).
# HF_TOKEN=

# Реранкер (опционально; по умолчанию выключен). Качает ~2 ГБ cross-encoder и требует torch.
# true → пост-ранжирование топа cross-encoder'ом (точнее, но медленнее).
# RERANK_ENABLED=false
# RERANK_MODEL=BAAI/bge-reranker-v2-m3

# ── MCP-сервер (Streamable HTTP) ────────────────────────────────────────────
# Интерфейс прослушивания. Локально 127.0.0.1; в контейнере app сам ставит 0.0.0.0
# (наружу публиковать только через TLS-прокси).
MCP_HOST=127.0.0.1
# Порт HTTP.
MCP_PORT=8000
# Путь MCP-эндпоинта (итог: http://host:port/mcp).
MCP_PATH=/mcp

# ── Общий публичный тенант (справка платформы/БСП — общая для всех проектов) ─
# Зарезервированный арендатор с ПУБЛИЧНЫМИ корпусами (platform_help, bsp_help, ...).
# Поиск/get_document/docinfo читают его АДДИТИВНО к арендатору клиента; список
# арендаторов формирует сервер (не из аргументов/заголовков клиента) → утечки нет.
# Заливать публичные корпуса: onec-vecgraph ingest-help --tenant-id __shared__ ...
# ВАЖНО: общий тенант эмбеддить той же моделью/размерностью, что и потребители.
SHARED_TENANT_ID=__shared__
# false — отключить аддитивное чтение общего тенанта.
INCLUDE_SHARED_TENANT=true

# ── Контекст арендатора ─────────────────────────────────────────────────────
# По HTTP арендатор/конфигурация берутся из заголовков X-Tenant-Id / X-Config-Id
# (или из bearer-токена, см. ниже). true → запрос БЕЗ X-Tenant-Id отклоняется
# (изоляция компаний). false разрешает дефолтный tenant без заголовка — только локалка.
REQUIRE_TENANT=true
# Арендатор по умолчанию (для stdio/CLI и при REQUIRE_TENANT=false).
DEFAULT_TENANT_ID=default
# Конфигурация по умолчанию: base | ext:<имя расширения>.
DEFAULT_CONFIG_ID=base

# ── Аутентификация HTTP (рекомендуется для сетевого доступа) ─────────────────
# true → каждый HTTP-вызов обязан нести 'Authorization: Bearer <token>'; арендатор
# (и опц. конфигурация) берутся из карты AUTH_TOKENS, а НЕ из подделываемого
# X-Tenant-Id. false → доверенный X-Tenant-Id (только за аутентифицирующим gateway).
AUTH_ENABLED=false
# Карта токенов: через запятую "token=tenant" или "token=tenant:config".
# По токену на потребителя/проект (удобно отзывать). Генерация стойкого токена:
#   python -c "import secrets; print('tok_' + secrets.token_urlsafe(32))"
# AUTH_TOKENS=tok_abc=acme,tok_xyz=globex:ext_crm

# ── Overlay WRITE-эндпоинт (baseline + per-task overlay; см. docs/OVERLAY.md) ────────────
# Отдельный ПИШУЩИЙ MCP-сервер (`onec-vecgraph serve-write`) с единственным инструментом
# index_overlay (инкрементальная индексация дельты разработчика в overlay-тенант '<base>@task/*').
# Read-сервер (`serve`) остаётся строго read-only. По умолчанию выключено.
# OVERLAY_WRITE_ENABLED=false
# Порт write-сервера (read-сервер слушает MCP_PORT; write — свой порт).
# WRITE_MCP_PORT=8001
# Карта write-токенов: "token=base". Токен может писать ТОЛЬКО в '<base>@task/*' (не в baseline,
# не в чужой проект). Без токенов — dev-режим (запись разрешена, но только в overlay-тенант).
# WRITE_AUTH_TOKENS=wtok=grand-dev-mdm@release

# ── Admin / baseline-реиндекс эндпоинт (для оркестратора; см. docs/ORCHESTRATOR_CONTRACT.md) ──
# Отдельный MAINTENANCE MCP-сервер (`onec-vecgraph serve-admin`): reindex_baseline (fire-and-poll
# полный index→callgraph→vectorize baseline-тенанта) + index_job_status (поллинг статуса). По
# умолчанию выключено; read- и overlay-write серверы не затрагиваются.
# BASELINE_REINDEX_ENABLED=false
# Порт admin-сервера (свой, отдельно от MCP_PORT/WRITE_MCP_PORT).
# ADMIN_MCP_PORT=8002
# Карта admin-токенов: "token=base". Токен может ЗАПУСКАТЬ baseline-реиндекс тенанта '<base>' —
# это запись ВСЕЙ базы (семантика ≠ WRITE_AUTH_TOKENS, который разрешает только overlay). Без
# токенов — dev-режим. (Принимается также написание ADMIN_AUTH_TOKENS.)
# ADMIN_TOKENS=atok=grand-dev-mdm@release
# Путь к JSON-файлу состояния джоб (чтобы index_job_status переживал рестарт; иначе только в памяти).
# BASELINE_JOBS_PATH=/state/baseline_jobs.json

# ── Совместимость env-имён с деплой-скелетом оркестратора (алиасы; оба написания работают) ──
# NEO4J_USERNAME == NEO4J_USER ; EMBEDDINGS_PROVIDER == EMBEDDING_PROVIDER ;
# ONEC_VECGRAPH_TENANT_ID == DEFAULT_TENANT_ID. Транспорт у нас — флаг CLI `serve --transport`.
