# ── Neo4j (graph + vectors) ─────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=onec_vecgraph_dev
NEO4J_DATABASE=neo4j

# ── Embeddings ──────────────────────────────────────────────────────────
# Provider: hashing | local | openai | voyage
#   hashing — dependency-free, deterministic, for dev/tests only
#   local   — Qwen3-Embedding / BGE-m3        (needs:  uv sync --extra local-embeddings)
#   openai  — text-embedding-3-large / -small / OpenAI-compatible gateway
#   voyage  — voyage-3 / voyage-3-large / ...  (openai|voyage need: --extra cloud-embeddings)
# NOTE: use the SAME provider+model for `vectorize` and for serving queries (the vector index
# dimension is fixed at vectorize time; mixing providers on one tenant breaks search).
EMBEDDING_PROVIDER=hashing
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu          # auto | cpu | cuda  (local provider)
EMBEDDING_DIM=256             # hashing provider only
# EMBEDDING_DIMENSIONS=1024   # cloud only: shrink output dims (OpenAI 3-*, Voyage 3-large/3.5); ≤4096
# OPENAI_API_KEY=
# OPENAI_BASE_URL=            # OpenAI-compatible gateway (Azure/proxy/self-hosted)
# VOYAGE_API_KEY=
# HF_TOKEN=                   # optional: HuggingFace token (removes model-download rate limit)

# ── MCP server (streamable-http) ────────────────────────────────────────
MCP_HOST=127.0.0.1
MCP_PORT=8000
MCP_PATH=/mcp

# ── Tenant context ──────────────────────────────────────────────────────
# Over HTTP the tenant/config come from request headers X-Tenant-Id / X-Config-Id.
# REQUIRE_TENANT=true rejects HTTP requests without X-Tenant-Id (company isolation).
# stdio (local dev) always uses the defaults below.
REQUIRE_TENANT=true
DEFAULT_TENANT_ID=default
DEFAULT_CONFIG_ID=base

# ── Auth (HTTP) ─────────────────────────────────────────────────────────
# AUTH_ENABLED=true → every HTTP call must carry `Authorization: Bearer <token>`; the tenant
# (and optional config) come from AUTH_TOKENS, NOT from a spoofable X-Tenant-Id header.
# AUTH_TOKENS: comma-separated "token=tenant" or "token=tenant:config" entries.
AUTH_ENABLED=false
# AUTH_TOKENS=tok_abc=acme,tok_xyz=globex:ext_crm
